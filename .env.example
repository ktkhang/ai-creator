# AI Creator - Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored and will NOT be committed.

# Required: OpenAI API key for song generation
OPENAI_API_KEY=

# Required: Gemini API key for song generation
GEMINI_API_KEY=

# Optional: Genius API key for lyrics search
GENIUS_API_KEY=

# Optional: Last.fm API key for track search (free, no premium needed)
LASTFM_API_KEY=
